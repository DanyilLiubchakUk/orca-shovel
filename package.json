{
  "name": "orca-shovel",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter @orca-shovel/web dev",
    "build": "bun --filter @orca-shovel/web build",
    "preview": "bun --filter @orca-shovel/web preview",
    "test": "bun --filter @orca-shovel/web test"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@tailwindcss/oxide"
  ],
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}
